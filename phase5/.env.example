# VeriTune environment variables
# Copy to .env and fill in your values

# ── API keys ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
WANDB_API_KEY=...
HF_TOKEN=...
TOGETHER_API_KEY=...

# ── Model paths ────────────────────────────────────────────────────────────────
ROUTER_PATH=outputs/router
REGISTRY_PATH=outputs/checkpoints/checkpoint_registry.json

# ── Serving ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=INFO
DEVICE=cpu                  # "cpu" | "cuda" | "mps"

# ── Database (for evaluation results) ─────────────────────────────────────────
DATABASE_URL=postgresql://veritune:password@localhost:5432/veritune

# ── WandB ──────────────────────────────────────────────────────────────────────
WANDB_PROJECT=veritune
WANDB_DISABLED=false        # set to "true" to disable W&B logging
